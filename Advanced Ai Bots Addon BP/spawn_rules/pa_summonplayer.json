          "min": 8.0,
          "max": 15.0,
          "adjust_for_weather": false
        },
        "minecraft:weight": {
          "default": 1
        },
        "minecraft:difficulty_filter": {
          "min": "easy",
          "max": "hard"
        },
        "minecraft:herd": {
          "min_size": 0,
          "max_size": 1
        },
        "minecraft:density_limit": {
          "surface": 2,
          "underground": 2
        },
        "minecraft:biome_filter": [
          {
            "any_of": [
              {
