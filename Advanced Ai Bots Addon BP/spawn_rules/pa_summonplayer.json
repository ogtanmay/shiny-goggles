{
  "format_version": "1.10.0",
  "minecraft:spawn_rules": {
    "description": {
      "identifier": "pa:summonplayer",
      "population_control": "cat"
    },
    "conditions": [
      {
        "minecraft:spawns_underground": {},
        "minecraft:spawns_on_surface": {},
